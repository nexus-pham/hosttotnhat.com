---
import Icon from '@/components/Icon.astro';
interface Props { feature: { title: string; description: string; icon: string } }
const { feature } = Astro.props;
---
<div class="bg-white p-8 rounded-3xl shadow-lg border border-slate-100 transition-all duration-300 hover:shadow-2xl hover:-translate-y-2 group">
  <div class="w-14 h-14 bg-az-blue/5 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-az-blue transition-colors">
    <Icon name={feature.icon} class="w-8 h-8 text-az-blue group-hover:text-white transition-colors" />
  </div>
  <h3 class="text-xl font-bold text-slate-900 mb-4">{feature.title}</h3>
  <p class="text-slate-600 leading-relaxed text-sm">{feature.description}</p>
</div>
