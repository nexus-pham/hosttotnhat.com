---
import type { CollectionEntry } from 'astro:content';
import Icon from '@/components/Icon.astro';
import { formatDate } from '@/lib/utils';
interface Props { post: CollectionEntry<'blog'> }
const { post } = Astro.props;
---
<a href={`/blog/${post.slug}/`} class="bg-white rounded-3xl overflow-hidden shadow-lg border border-slate-100 transition-all duration-300 hover:shadow-2xl group cursor-pointer block">
  <div class="h-48 overflow-hidden relative">
    <img src={post.data.image ?? `https://picsum.photos/seed/${post.slug}/600/400`} alt={post.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" referrerpolicy="no-referrer" />
    <div class="absolute top-4 left-4 bg-az-blue text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-widest">{post.data.category}</div>
  </div>
  <div class="p-6">
    <div class="flex items-center text-slate-400 text-xs mb-3">
      <Icon name="calendar" class="w-3 h-3 mr-1" />
      {formatDate(post.data.date)}
    </div>
    <h3 class="text-lg font-bold text-slate-900 mb-3 group-hover:text-az-blue transition-colors leading-snug">{post.data.title}</h3>
    <p class="text-slate-600 text-sm mb-6 line-clamp-2">{post.data.excerpt}</p>
    <span class="inline-flex items-center text-az-blue font-bold text-sm hover:underline">Đọc tiếp <Icon name="arrow-right" class="ml-2 w-4 h-4" /></span>
  </div>
</a>
