---
import { siteConfig } from '@/data/site-config';
import Icon from '@/components/Icon.astro';
---
<footer class="bg-slate-900 pt-20 pb-10 text-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-4">
      <div class="col-span-1 lg:col-span-1">
        <div class="mb-6 flex items-center space-x-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-az-blue text-white">
            <Icon name={siteConfig.logoIcon} class="h-5 w-5" />
          </div>
          <div>
            <span class="block text-xl font-display font-bold tracking-tight">{siteConfig.brandName}</span>
            <span class="block text-xs font-semibold tracking-[0.2em] text-az-red uppercase">Đánh giá hosting thực tế</span>
          </div>
        </div>
        <p class="mb-6 text-sm leading-relaxed text-slate-400">Host Tốt Nhất là website vệ tinh nội dung tập trung vào việc đánh giá, so sánh và hướng dẫn chọn hosting phù hợp tại Việt Nam. Thông tin liên hệ và dịch vụ được đối chiếu theo AZDIGI.</p>
        <div class="flex space-x-4">
          {siteConfig.socialLinks.map((social) => (
            <a href={social.href} target="_blank" rel="noopener noreferrer" class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-800 transition-colors hover:bg-az-blue" aria-label={social.label}>
              <Icon name={social.icon} class="h-5 w-5" />
            </a>
          ))}
        </div>
      </div>
      <div>
        <h4 class="mb-6 text-lg font-bold">Dịch vụ</h4>
        <ul class="space-y-4 text-sm text-slate-400">{siteConfig.footerServices.map((item) => <li><a href={siteConfig.ctas.register} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">{item}</a></li>)}</ul>
      </div>
      <div>
        <h4 class="mb-6 text-lg font-bold">Hỗ trợ</h4>
        <ul class="space-y-4 text-sm text-slate-400">{siteConfig.footerSupport.map((item) => <li><a href={siteConfig.ctas.consultation} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">{item}</a></li>)}</ul>
      </div>
      <div>
        <h4 class="mb-6 text-lg font-bold">Thông tin AZDIGI</h4>
        <ul class="space-y-4 text-sm text-slate-400">
          <li class="flex items-start"><Icon name="map-pin" class="mr-3 mt-0.5 h-5 w-5 flex-shrink-0 text-az-blue" /><span>{siteConfig.contact.address}</span></li>
          <li class="flex items-center"><Icon name="phone" class="mr-3 h-5 w-5 flex-shrink-0 text-az-blue" /><span>{siteConfig.contact.phoneDisplay}</span></li>
          <li class="flex items-center"><Icon name="mail" class="mr-3 h-5 w-5 flex-shrink-0 text-az-blue" /><span>{siteConfig.contact.email}</span></li>
          <li class="flex items-center"><Icon name="file-text" class="mr-3 h-5 w-5 flex-shrink-0 text-az-blue" /><span>MST: {siteConfig.contact.taxCode}</span></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-slate-800 pt-8 text-center text-xs text-slate-500">
      <p>© 2026 {siteConfig.brandName}. Nội dung định hướng SEO, thông tin dịch vụ được tham chiếu từ AZDIGI.</p>
    </div>
  </div>
</footer>
