---
import Icon from '@/components/Icon.astro';
import { siteConfig } from '@/data/site-config';
---
<div class="relative overflow-hidden bg-white pt-16 pb-24 lg:pt-24 lg:pb-32">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 h-full w-full opacity-5 pointer-events-none">
    <div class="absolute top-10 left-10 h-64 w-64 rounded-full bg-az-blue blur-3xl"></div>
    <div class="absolute bottom-10 right-10 h-96 w-96 rounded-full bg-az-red blur-3xl"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="items-center gap-12 lg:grid lg:grid-cols-12">
      <div class="fade-slide-up sm:text-center md:mx-auto md:max-w-2xl lg:col-span-7 lg:text-left">
        <div class="mb-6 inline-flex items-center rounded-full bg-az-blue/10 px-4 py-1.5 text-sm font-semibold tracking-wide text-az-blue uppercase">
          <Icon name="star" class="mr-2 h-4 w-4" />
          Review hosting thực tế
        </div>
        <h1 class="text-4xl leading-tight font-extrabold tracking-tight text-slate-900 sm:text-5xl md:text-6xl lg:text-7xl">
          Hosting tốt nhất tại Việt Nam <span class="text-az-blue">— Đánh giá thực tế, không PR</span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 sm:text-xl md:mt-8">
          Host Tốt Nhất tổng hợp tiêu chí chọn hosting, so sánh các nhóm dịch vụ phổ biến và gợi ý cấu hình phù hợp theo từng nhu cầu: blog cá nhân, WordPress, website bán hàng hay website doanh nghiệp.
        </p>
        <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:justify-center lg:justify-start">
          <a href="#pricing" class="az-button-primary flex items-center justify-center">
            Xem bảng giá tham khảo <Icon name="arrow-right" class="ml-2 h-5 w-5" />
          </a>
          <a href="/blog/cach-chon-hosting-phu-hop/" class="az-button-outline flex items-center justify-center">
            Xem tiêu chí chọn hosting
          </a>
        </div>

        <div class="mt-12 grid grid-cols-1 gap-4 border-t border-slate-100 pt-8 sm:grid-cols-3 sm:gap-6">
          <div class="flex items-center gap-3">
            <div class="rounded-lg bg-az-blue/5 p-2"><Icon name="gauge" class="h-5 w-5 text-az-blue" /></div>
            <span class="text-sm font-medium text-slate-700">Tốc độ & uptime</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="rounded-lg bg-az-blue/5 p-2"><Icon name="shield-check" class="h-5 w-5 text-az-blue" /></div>
            <span class="text-sm font-medium text-slate-700">Bảo mật & backup</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="rounded-lg bg-az-blue/5 p-2"><Icon name="headphones" class="h-5 w-5 text-az-blue" /></div>
            <span class="text-sm font-medium text-slate-700">Support khi có sự cố</span>
          </div>
        </div>
      </div>

      <div class="fade-scale-in delay-200 mt-16 sm:mt-24 lg:col-span-5 lg:mt-0">
        <div class="relative mx-auto w-full max-w-md lg:max-w-none">
          <div class="group relative overflow-hidden rounded-3xl border border-white bg-slate-50 p-8 shadow-2xl">
            <div class="absolute top-0 right-0 -mt-10 -mr-10 h-32 w-32 rounded-bl-full bg-az-red/10 transition-transform group-hover:scale-110"></div>
            <div class="relative z-10">
              <div class="mb-8 flex items-center justify-between">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-az-blue text-white shadow-lg shadow-az-blue/20">
                  <Icon name="award" class="h-6 w-6" />
                </div>
                <div class="text-right">
                  <div class="text-xs font-bold tracking-widest text-slate-400 uppercase">Điểm đánh giá</div>
                  <div class="font-display text-2xl font-bold text-az-blue">Rõ ràng & thực dụng</div>
                </div>
              </div>

              <div class="space-y-6">
                {[
                  { label: 'Hiệu năng thực tế', value: '9.2/10', width: '92%', color: 'bg-az-blue' },
                  { label: 'Mức độ dễ quản trị', value: '8.8/10', width: '88%', color: 'bg-az-blue' },
                  { label: 'Tỷ lệ đáng tiền', value: '9.0/10', width: '90%', color: 'bg-az-red' },
                ].map((item) => (
                  <div class="rounded-xl border border-slate-100 bg-white p-4 shadow-sm">
                    <div class="mb-2 flex items-center justify-between">
                      <span class="text-sm font-semibold text-slate-700">{item.label}</span>
                      <span class="text-xs font-bold text-az-blue">{item.value}</span>
                    </div>
                    <div class="h-2 w-full rounded-full bg-slate-100">
                      <div class:list={[item.color, 'h-2 rounded-full']} style={{ width: item.width }}></div>
                    </div>
                  </div>
                ))}
              </div>

              <div class="mt-8 grid grid-cols-2 gap-4 border-t border-slate-200 pt-6">
                <div class="rounded-2xl border border-slate-100 bg-white p-4 text-center">
                  <div class="text-2xl font-bold text-az-blue">3 nhóm</div>
                  <div class="text-sm text-slate-500">dịch vụ nổi bật</div>
                </div>
                <div class="rounded-2xl border border-slate-100 bg-white p-4 text-center">
                  <div class="text-2xl font-bold text-az-red">24/7</div>
                  <div class="text-sm text-slate-500">là mức support nên có</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
