---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Icon from '@/components/Icon.astro';
import type { CollectionEntry } from 'astro:content';
import { formatDate, absoluteUrl } from '@/lib/utils';
import { siteConfig } from '@/data/site-config';

interface Props {
  post: CollectionEntry<'blog'>;
  relatedPosts: CollectionEntry<'blog'>[];
}

const { post, relatedPosts } = Astro.props;
const pageTitle = `${post.data.title} | ${siteConfig.brandName}`;
const pageDescription = post.data.excerpt;
const pagePath = `/blog/${post.slug}/`;
const articleImage = post.data.image ?? `https://picsum.photos/seed/${post.slug}/1920/1080`;
const blogPosting = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.excerpt,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  image: [articleImage],
  author: { '@type': 'Person', name: post.data.author },
  publisher: { '@type': 'Organization', name: siteConfig.brandName, url: siteConfig.siteUrl },
  mainEntityOfPage: absoluteUrl(siteConfig.siteUrl, pagePath),
};
const faqSchema = post.data.faq?.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: post.data.faq.map((item) => ({ '@type': 'Question', name: item.question, acceptedAnswer: { '@type': 'Answer', text: item.answer } }))
} : undefined;
---
<BaseLayout title={pageTitle} description={pageDescription} path={pagePath} image={articleImage} type="article" jsonLd={[blogPosting, ...(faqSchema ? [faqSchema] : [])]}>
  <div class="bg-white">
    <div class="relative h-[400px] lg:h-[500px] overflow-hidden">
      <img src={articleImage} alt={post.data.title} class="w-full h-full object-cover" referrerpolicy="no-referrer" />
      <div class="absolute inset-0 bg-linear-to-t from-slate-900 via-slate-900/40 to-transparent"></div>
      <div class="absolute bottom-0 left-0 w-full p-8 lg:p-16">
        <div class="max-w-4xl mx-auto">
          <a href="/blog/" class="inline-flex items-center text-white/80 hover:text-white mb-6 transition-colors group"><Icon name="arrow-left" class="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" />Quay lại danh sách</a>
          <div class="flex items-center space-x-4 mb-4"><span class="bg-az-red text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-widest">{post.data.category}</span><div class="flex items-center text-white/80 text-sm"><Icon name="calendar" class="w-4 h-4 mr-1" />{formatDate(post.data.date)}</div></div>
          <h1 class="text-3xl lg:text-5xl font-extrabold text-white leading-tight mb-6">{post.data.title}</h1>
          <div class="flex items-center space-x-6"><div class="flex items-center text-white/90"><div class="w-10 h-10 rounded-full bg-az-blue flex items-center justify-center mr-3 border-2 border-white/20"><Icon name="user" class="w-5 h-5" /></div><span class="font-medium">{post.data.author}</span></div></div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="lg:grid lg:grid-cols-12 lg:gap-16">
        <article class="lg:col-span-8">
          <div class="prose prose-lg article-prose prose-blockquote:border-l-4 prose-blockquote:border-az-red prose-blockquote:bg-slate-50 prose-blockquote:py-2 prose-blockquote:pl-6 prose-blockquote:rounded-r-lg">
            <p class="text-xl font-medium text-slate-900 leading-relaxed italic border-l-4 border-az-red pl-6 py-2 bg-slate-50 rounded-r-lg">{post.data.excerpt}</p>
            <div class="overflow-x-auto">
              <slot />
            </div>
          </div>

          {post.data.faq?.length && (
            <section class="mt-16 pt-8 border-t border-slate-100">
              <h2 class="text-2xl font-bold text-slate-900 mb-6">Câu hỏi thường gặp</h2>
              <div class="space-y-4">
                {post.data.faq.map((item) => (
                  <div class="rounded-2xl border border-slate-100 bg-slate-50 p-6">
                    <h3 class="text-lg font-bold text-slate-900 mb-3">{item.question}</h3>
                    <p class="text-slate-600">{item.answer}</p>
                  </div>
                ))}
              </div>
            </section>
          )}

          <div class="mt-16 pt-8 border-t border-slate-100 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
            <div class="flex items-center space-x-2"><Icon name="tag" class="w-4 h-4 text-slate-400" /><div class="flex flex-wrap gap-2">{post.data.tags.map((tag) => <span class="text-xs font-medium text-slate-500 bg-slate-100 px-3 py-1 rounded-full hover:bg-az-blue/10 hover:text-az-blue transition-colors">#{tag}</span>)}</div></div>
            <div class="flex items-center space-x-4"><span class="text-sm font-bold text-slate-400 uppercase tracking-widest">Chia sẻ:</span><div class="flex space-x-2"><a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(absoluteUrl(siteConfig.siteUrl, pagePath))}`} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-[#1877F2] hover:text-white transition-all"><Icon name="facebook" class="w-5 h-5" /></a><a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(absoluteUrl(siteConfig.siteUrl, pagePath))}&text=${encodeURIComponent(post.data.title)}`} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-[#1DA1F2] hover:text-white transition-all"><Icon name="twitter" class="w-5 h-5" /></a><a href={absoluteUrl(siteConfig.siteUrl, pagePath)} class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-az-blue hover:text-white transition-all"><Icon name="link" class="w-5 h-5" /></a></div></div>
          </div>
        </article>

        <aside class="lg:col-span-4 mt-16 lg:mt-0">
          <div class="sticky top-24 space-y-12">
            <div class="bg-slate-900 rounded-3xl p-8 text-white relative overflow-hidden"><div class="absolute top-0 right-0 w-24 h-24 bg-az-red/20 rounded-bl-full"></div><h3 class="text-2xl font-bold mb-4 relative z-10">Cần hạ tầng ổn định hơn?</h3><p class="text-slate-400 text-sm mb-8 relative z-10 leading-relaxed">Khám phá Premium Business Hosting để chạy website doanh nghiệp nhanh hơn, ổn định hơn và có đội ngũ AZDIGI đồng hành 24/7.</p><a href={siteConfig.ctas.register} target="_blank" rel="noopener noreferrer" class="az-button-primary w-full text-center block relative z-10">Xem bảng giá</a></div>
            {relatedPosts.length > 0 && <div>
              <h3 class="text-xl font-bold text-slate-900 mb-6 flex items-center"><span class="w-2 h-8 bg-az-red rounded-full mr-3"></span>Bài viết liên quan</h3>
              <div class="space-y-6">
                {relatedPosts.map((related, i) => (
                  <a href={`/blog/${related.slug}/`} class="flex items-start group"><div class="w-20 h-20 flex-shrink-0 rounded-xl overflow-hidden mr-4"><img src={related.data.image ?? `https://picsum.photos/seed/related-${i + 1}/150/150`} alt={related.data.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" referrerpolicy="no-referrer" /></div><div><h4 class="text-sm font-bold text-slate-900 group-hover:text-az-blue transition-colors line-clamp-2 leading-snug">{related.data.title}</h4><span class="text-xs text-slate-400 mt-2 block">{formatDate(related.data.date)}</span></div></a>
                ))}
              </div>
            </div>}
          </div>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>
