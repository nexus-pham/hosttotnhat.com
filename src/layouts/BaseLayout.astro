---
import '@/styles/global.css';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import SEOHead from '@/components/SEOHead.astro';
import { siteConfig } from '@/data/site-config';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: object | object[];
}
const { title, description, path = Astro.url.pathname, image, type = 'website', jsonLd } = Astro.props;
---
<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEOHead title={title} description={description} path={path} image={image} type={type} jsonLd={jsonLd} />
    {siteConfig.googleSiteVerification && (
      <meta name="google-site-verification" content={siteConfig.googleSiteVerification} />
    )}
    {siteConfig.ga4MeasurementId !== 'G-XXXXXXXXXX' && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${siteConfig.ga4MeasurementId}`}></script>
        <script is:inline define:vars={{ gaId: siteConfig.ga4MeasurementId }}>window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', gaId);</script>
      </>
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <Navbar currentPath={Astro.url.pathname} />
    <main class="flex-grow"><slot /></main>
    <Footer />
  </body>
</html>
